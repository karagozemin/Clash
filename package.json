{
  "name": "veil",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm --workspace @veil/server run dev",
    "dev:web": "npm --workspace @veil/web run dev",
    "build": "npm-run-all build:server build:web",
    "build:server": "npm --workspace @veil/server run build",
    "build:web": "npm --workspace @veil/web run build",
    "test": "npm --workspace @veil/server run test",
    "check:live": "node scripts/live-readiness.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "dotenv": "^16.4.7",
    "npm-run-all": "^4.1.5"
  }
}
